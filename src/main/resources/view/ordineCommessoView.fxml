<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.ispw.project.graphicController.OrdineCommessoGraphicController">

    <children>
        <AnchorPane prefHeight="400.0"
                    prefWidth="500.0"
                    style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);
                           -fx-background-radius: 15;
                           -fx-background-color: #f8f9fa;"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <children>

                <!-- Titolo -->
                <Label fx:id="lblTitoloOrdine"
                       text=" ORDINE N°"
                       AnchorPane.leftAnchor="10.0"
                       AnchorPane.topAnchor="10.0">
                    <font>
                        <Font name="System Bold" size="24.0"/>
                    </font>
                </Label>

                <!-- Lista articoli -->
                <ScrollPane fitToWidth="true"
                            AnchorPane.topAnchor="50.0"
                            AnchorPane.bottomAnchor="75.0"
                            AnchorPane.leftAnchor="10.0"
                            AnchorPane.rightAnchor="10.0">

                    <content>
                        <VBox fx:id="vboxArticoli"
                              spacing="15.0"
                              prefWidth="450.0">
                            <padding>
                                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>

                <!-- Bottone Chiudi -->
                <Button fx:id="btnChiudi"
                        text="X"
                        onAction="#onChiudiClick"
                        prefHeight="26.0"
                        prefWidth="42.0"
                        AnchorPane.topAnchor="0.0"
                        AnchorPane.rightAnchor="0.0"
                        style="
                            -fx-background-color: transparent;
                            -fx-font-weight: bold;
                            -fx-text-fill: #999999;
                            -fx-font-size: 18;
                            -fx-cursor: hand;
                        "/>

                <!-- Bottone Ordine Pronto -->
                <StackPane prefHeight="64.0"
                           AnchorPane.bottomAnchor="0.0"
                           AnchorPane.leftAnchor="0.0"
                           AnchorPane.rightAnchor="0.0">

                    <children>
                        <Button fx:id="btnOrdinePronto"
                                text="Ordine Pronto"
                                onAction="#onOrdineProntoClick"
                                mnemonicParsing="false"
                                styleClass="bottone-giallo"
                                stylesheets="@../style.css"/>
                    </children>
                </StackPane>

            </children>
        </AnchorPane>
    </children>
</AnchorPane>